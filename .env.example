# ---- LLM (extraction + conversational agent) ----
# Anthropic is the default provider, used through PydanticAI.
ANTHROPIC_API_KEY=sk-ant-...
# Provider-prefixed model id understood by PydanticAI. Default is a small/cheap model.
LLM_MODEL=anthropic:claude-haiku-4-5
# Hard cap on output tokens per LLM call (cost/safety guard).
LLM_MAX_TOKENS=2048

# ---- Embeddings (RAG) ----
# Anthropic has no embeddings endpoint, so embeddings sit behind a swappable
# provider interface. "local" runs fully offline via fastembed (no extra key).
# Alternatives: "voyage" (set VOYAGE_API_KEY) or "openai" (set OPENAI_API_KEY).
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
# VOYAGE_API_KEY=
# OPENAI_API_KEY=

# ---- Database ----
# Async SQLAlchemy URL (asyncpg driver). Matches docker-compose defaults.
DATABASE_URL=postgresql+asyncpg://npo:npo@localhost:5432/npo
# Used by docker-compose; keep in sync with DATABASE_URL above.
POSTGRES_USER=npo
POSTGRES_PASSWORD=npo
POSTGRES_DB=npo
POSTGRES_PORT=5432

# ---- App ----
# Comma-separated CORS origins for the frontend dev server.
CORS_ORIGINS=http://localhost:5173
# Ingestion guards so a huge PDF can't blow the context window.
MAX_UPLOAD_MB=10
MAX_INPUT_CHARS=60000
